<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <AssemblyName>DynamoCoreUpdate</AssemblyName>
    <RootNamespace>DynamoCoreUpdate</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyTitle>DynamoCore 3.6.2 Update for Revit 2026</AssemblyTitle>
    <AssemblyVersion>3.6.2.0</AssemblyVersion>
    <FileVersion>3.6.2.0</FileVersion>
  </PropertyGroup>

  <!-- Publish profile: single self-contained exe -->
  <PropertyGroup Condition="'$(PublishSingleFile)' == 'true'">
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>


  <Target Name="CopyToDistFolder" AfterTargets="Publish">
    <MakeDir Directories="$(MSBuildProjectDirectory)\dist" />
    <Copy SourceFiles="$(PublishDir)$(AssemblyName).exe" DestinationFolder="$(MSBuildProjectDirectory)\dist" />
  </Target>

</Project>
